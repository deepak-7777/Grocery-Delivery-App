<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:layout_height="match_parent"
    tools:context=".ui.ongoingorders.ongoingorders">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="127dp"
        android:layout_height="95dp"
        android:layout_marginLeft="95dp"
        android:layout_marginTop="70dp"
        android:src="@drawable/order" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="95dp"
        android:paddingTop="157dp"
        android:textColor="@color/black"
        android:textSize="17sp"
        android:text="Your cart is empty" />

    <TextView
        android:id="@+id/ongoingorder"
        android:layout_width="210dp"
        android:layout_height="40dp"
        android:layout_marginLeft="60dp"
        android:layout_marginTop="205dp"
        android:background="@drawable/username_bg"
        android:backgroundTint="#D0CECE"
        android:paddingLeft="40dp"
        android:paddingTop="8dp"
        android:textStyle="bold"
        android:text="Browse Products"
        android:textColor="#5E06AF"
        android:textSize="17sp" />


</FrameLayout>