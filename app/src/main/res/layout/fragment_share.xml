<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".ui.share.share">


    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="315dp"
        android:layout_height="196dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="30dp"
        android:background="@color/white"
        android:scaleType="centerCrop"
        android:src="@drawable/history1"
        tools:ignore="SpeakableTextPresentCheck" />
    <View
        android:layout_width="match_parent"
        android:background="#3C3B3B"
        android:layout_height="1dp"
        android:layout_marginLeft="17dp"
        android:layout_marginRight="17dp"
        android:layout_marginTop="230dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:id="@+id/contact3"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="240dp"
        android:text="If you like our app please take a moment to share it with your friends &amp; family."
        android:textColor="#5D5A5A"
        android:textSize="19dp" />
    <View
        android:layout_width="match_parent"
        android:background="#3C3B3B"
        android:layout_height="1dp"
        android:layout_marginLeft="17dp"
        android:layout_marginRight="17dp"
        android:layout_marginTop="320dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:id="@+id/link"
        android:layout_height="wrap_content"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="350dp"
        android:text="@string/link"
        android:textColor="@color/black"
        android:textSize="22dp" />
</FrameLayout>