<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.history.history">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="127dp"
        android:layout_height="95dp"
        android:layout_marginLeft="100dp"
        android:layout_marginTop="80dp"
        android:src="@drawable/history" />
    <TextView
        android:id="@+id/textView20"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="35dp"
        android:layout_marginTop="180dp"
        android:layout_marginRight="5dp"
        android:text="No browsing history yet"
        android:textColor="@color/black"
        android:textSize="27dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textView21"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="13dp"
        android:layout_marginTop="225dp"
        android:layout_marginRight="25dp"
        android:text="Your previously visited Products will be shown here."
        android:textColor="#3E3B3B"
        android:textSize="18dp" />

    <TextView
        android:id="@+id/history1"
        android:layout_width="129dp"
        android:layout_height="45dp"
        android:layout_marginLeft="115dp"
        android:layout_marginTop="310dp"
        android:background="@drawable/username_bg"
        android:backgroundTint="#1B1B1B"
        android:paddingLeft="33dp"
        android:paddingTop="8dp"
        android:text="Go Back"
        android:textColor="@color/white"
        android:textSize="19sp"
        android:textStyle="bold" />

</FrameLayout>